# ============================================================
# WOWVote 환경변수 템플릿
# ============================================================
# 사용법: 이 파일을 복사해서 ".env"로 이름을 바꾸고 본인 값 입력
#   cp .env.example .env
#
# ⚠️ .env 파일은 절대 git에 올리지 마세요 (.gitignore에 이미 포함됨)
# ⚠️ service_role 키는 절대 여기에 넣지 마세요 (클라이언트 노출 금지)
# ============================================================

# Supabase 프로젝트 URL
# 위치: Supabase 콘솔 > Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon public 키 (공개해도 되는 키, RLS로 보호됨)
# 위치: Supabase 콘솔 > Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=eyJhbGciOi...

# A에서 사용할 기본 세션 코드 (변경 불필요, B/C에서 활용)
DEFAULT_SESSION_CODE=default
